@startdot
digraph SortDG {
  graph [layout=neato, splines=ortho, bgcolor=white, overlap=false];
  node  [fontsize=8];
  edge  [fontsize=7, arrowsize=0.55];

  node [shape=circle, style=filled, fillcolor="#cce5ff",
        width=0.55, height=0.55, fixedsize=true, fontsize=8];

  // row 0
  P00 [label="0,0", pos="0,8!"];
  P01 [label="0,1", pos="2,8!"];
  P02 [label="0,2", pos="4,8!"];
  P03 [label="0,3", pos="6,8!"];
  P04 [label="0,4", pos="8,8!"];

  // row 1
  P11 [label="1,1", pos="2,6!"];
  P12 [label="1,2", pos="4,6!"];
  P13 [label="1,3", pos="6,6!"];
  P14 [label="1,4", pos="8,6!"];

  // row 2
  P22 [label="2,2", pos="4,4!"];
  P23 [label="2,3", pos="6,4!"];
  P24 [label="2,4", pos="8,4!"];

  // row 3
  P33 [label="3,3", pos="6,2!"];
  P34 [label="3,4", pos="8,2!"];

  // row 4
  P44 [label="4,4", pos="8,0!"];

  // входные данные сверху
  node [shape=plaintext, width=0.4, height=0.3, fixedsize=false, fontsize=8];
  A0 [label="a[0]", pos="0,9.2!"];
  A1 [label="a[1]", pos="2,9.2!"];
  A2 [label="a[2]", pos="4,9.2!"];
  A3 [label="a[3]", pos="6,9.2!"];
  A4 [label="a[4]", pos="8,9.2!"];

  // P(0,0) раздает элементы первой строке
  edge [color="#228b22", penwidth=1.1, style=solid, arrowsize=0.6];
  A0->P00; A1->P01; A2->P02; A3->P03; A4->P04;

  // min течет вправо (синий)
  edge [color=blue, penwidth=1.3, style=solid, arrowsize=0.7];
  P00->P01 [label="min", fontcolor=blue, fontsize=8];
  P01->P02; P02->P03; P03->P04;
  P11->P12; P12->P13; P13->P14;
  P22->P23; P23->P24;
  P33->P34;

  // max течет вниз (оранжевый)
  edge [color=orange, penwidth=1.3, style=solid, arrowsize=0.7];
  P01->P11 [label="max", fontcolor=orange, fontsize=8];
  P02->P12; P03->P13; P04->P14;
  P12->P22; P13->P23; P14->P24;
  P23->P33; P24->P34;
  P34->P44;

}
@enddot
